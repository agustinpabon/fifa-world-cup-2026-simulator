{
  "name": "@workspace/scripts",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "backtest": "tsx ./src/backtest.ts",
    "hello": "tsx ./src/hello.ts",
    "optimize": "tsx ./src/optimize.ts",
    "test": "tsx --test \"src/**/*.test.ts\"",
    "test:coverage": "node --experimental-test-coverage --test-coverage-lines=80 --import tsx --test \"src/**/*.test.ts\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@workspace/oracle-model": "workspace:*",
    "@types/node": "catalog:",
    "tsx": "catalog:"
  }
}
